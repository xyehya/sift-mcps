// RUN-3: allow the sift service account to start only transient run_command
// scopes created by sift_core.execute.executor. This lets systemd apply
// --uid/--gid and cgroup properties non-interactively without granting a shell
// or broad unit-management rights.
polkit.addRule(function(action, subject) {
    if (action.id !== "org.freedesktop.systemd1.manage-units") {
        return;
    }
    if (subject.user !== "@@SIFT_GATEWAY_SERVICE_USER@@") {
        return;
    }

    var unit = action.lookup("unit");
    var verb = action.lookup("verb");
    if (!unit || !verb) {
        return;
    }

    if (/^sift-run-command-[A-Za-z0-9_.-]+\.scope$/.test(unit) &&
        (verb === "start" || verb === "stop")) {
        return polkit.Result.YES;
    }
});
