  classDef outer fill:#ffffff,stroke:#111111,stroke-width:2px,color:#111111;
  classDef gw fill:#ffffff,stroke:#111111,stroke-width:2.2px,color:#111111;

  class Portal,Agents,B1,B2,B3,B4,B5,B6,B7,B8,B9,Worker,Sandbox,OpenCTI,WinTriage box;
  class Supabase,OpenSearch,Evidence,Reports db;
  class Gateway gw;
  class CONTROL,EXECUTION,ADDONS group;
  class SYSTEM outer;

  style CLIENTS fill:#ffffff,stroke:transparent
  style CP_BOXES fill:#ffffff,stroke:transparent
