flowchart TB

  %% =========================================================
  %% SIFT VM Autonomous DFIR Agent - target architecture with current
  %% post-D27b migration status called out.
  %%
  %% Canonical decisions reflected in this diagram (see
  %% 00_migration_charter.md "Confirmed Decisions (Locked)"):
  %%  - The Gateway is the SINGLE policy boundary. ALL REST APIs,
  %%    ALL MCP tool calls, and ALL privileged actions go through it.
  %%    Per-backend direct MCP routes (/mcp/{name}) are DISABLED.
  %%  - Supabase/Postgres is the authoritative control plane.
  %%  - There is NEVER a direct job/invoke to the Evidence Vault.
  %%    Tool calls (ingest/search/etc.) enter the Gateway, which
  %%    enqueues durable jobs/pipelines in the control plane; workers
  %%    CLAIM (poll + SKIP LOCKED) those jobs and run the pipelines.
  %%  - TARGET: ACTIVE CASE is selected by the operator in the portal only,
  %%    is authoritative in the control plane, and the Gateway propagates it
  %%    to every backend/API/tool call. CURRENT: this is still pending
  %%    Phase ID-4/ID-5; D27b preserved legacy compatibility.
  %%  - OpenSearch 3.5.0 with security ENABLED is the derived
  %%    search/data plane. It is never authoritative.
  %%  - AI agents reach tools ONLY through Gateway MCP tools and run
  %%    deeper analysis in a sandboxed, allowlisted execution plane.
  %% Note: Mermaid auto-layout is not pixel-perfect.
  %% =========================================================

  subgraph SYSTEM["SIFT VM Autonomous DFIR Agent - Target Architecture (Post-D27b Status)"]
    direction TB

    %% -------------------------
    %% Clients
    %% -------------------------
    subgraph CLIENTS[" "]
      direction LR

      Portal("<b>Presentation Layer</b><br/>React + Vite Operator Portal<br/><br/>Case lifecycle, <b>ACTIVE CASE selection</b>,<br/>findings + approvals, timeline, TODOs, IOCs,<br/>evidence integrity, MCP token management,<br/>reports, AI-agent activity review<br/><i>Supabase human auth pending ID-3</i>")

      Agents("<b>AI Agent Clients</b><br/>Codex / Claude / Local MCP Clients<br/><br/>Gateway-mediated MCP tools only<br/>case-data tools are case-scoped;<br/>global add-ons are tool-scoped + audited<br/>(no direct backend, no direct OpenSearch)")
    end

    %% -------------------------
    %% Gateway - single policy boundary
    %% -------------------------
    Gateway("<b>Gateway / Broker Layer - SINGLE POLICY BOUNDARY</b><br/>FastAPI + FastMCP 3.0 <b>LANDED D27b</b><br/>(one ASGI app: REST + aggregate mcp.http_app at /mcp)<br/><br/>ALL REST APIs + ALL MCP tool calls + ALL privileged actions<br/>AuthN / AuthZ, case scope, tool scope, evidence gate,<br/>audit + policy enforcement, OpenSearch query mediation<br/><i>policy is SIFT-owned middleware/service logic</i><br/><i>per-backend direct MCP routes REMOVED</i><br/><i>control-plane active-case propagation pending ID-4/ID-5</i>")

    %% -------------------------
    %% Control plane (authoritative)
    %% -------------------------
    subgraph CONTROL["Case Control Plane - AUTHORITATIVE"]
      direction TB

      Supabase[("<b>Supabase Local / Postgres</b><br/>Auth + RLS + Storage<br/><i>Source of truth</i>")]

      subgraph CP_BOXES[" "]
        direction TB
        B1["<b>Identity + Auth + Case Membership</b><br/><i>schema done; human auth pending ID-3</i>"]
        B2["<b>MCP / Service Token Registry</b> (hash-only)<br/><i>runtime dual-validation done PR02</i>"]
        B3["<b>Active Case State</b> (portal-set)<br/><i>authority/propagation pending ID-4/ID-5</i>"]
        B4["<b>Cases / Findings / Approvals / TODOs / IOCs / Timeline refs</b>"]
        B5["<b>Evidence Metadata + Integrity + Anchoring state</b>"]
        B6["<b>Durable Jobs / Steps / Logs / Pipeline State</b>"]
        B7["<b>Audit Events</b>"]
        B8["<b>Reports + Report Artifacts</b>"]
        B9["<b>RAG Collections + Agent Skills (skills.md)</b>"]
      end

      Supabase --- B1
      Supabase --- B2
      Supabase --- B3
      Supabase --- B4
      Supabase --- B5
      Supabase --- B6
      Supabase --- B7
      Supabase --- B8
      Supabase --- B9
    end

    %% -------------------------
    %% Data plane + Evidence vault
    %% -------------------------
    OpenSearch[("<b>OpenSearch 3.5.0 (Security ON)</b><br/><b>Target core</b> derived search / data plane<br/><b>case-*</b> SIFT indices + <b>opencti_*</b> OpenCTI indices<br/>per-consumer scoped roles - agent has no cluster creds<br/>artifacts, timeline, IOCs, full-text + vector<br/><i>final core move pending OpenSearch phase</i>")]

    Evidence[("<b>Evidence Vault</b><br/>Immutable raw evidence files + hashes<br/>manifest + ledger proof artifacts")]

    %% -------------------------
    %% Execution plane
    %% -------------------------
    subgraph EXECUTION["Execution Plane - SIFT VM Workers"]
      direction TB

      Worker("<b>SIFT VM Worker Runtime</b><br/>Claim durable jobs from Postgres (poll + SKIP LOCKED)<br/>Ingestion pipelines, parsers, normalization,<br/>evidence operations, report generation")

      Sandbox["<b>Sandboxed Agent Tool Execution</b><br/>run_command / deeper extraction<br/>shell-free, allowlisted, case-jailed"]

      Worker --- Sandbox
    end

    Reports[("<b>Reports / Exports</b><br/>HTML / PDF / JSON bundles")]

    %% -------------------------
    %% Add-on MCP backends (target: registered in control-plane mcp_backends;
    %% current: read from gateway.yaml until D22/F-11 lands; reached ONLY
    %% through the Gateway aggregate policy path)
    %% -------------------------
    subgraph ADDONS["Add-on MCP Backends - query-only (current gateway.yaml, target mcp_backends)"]
      direction LR
      OpenSearchCompat("<b>opensearch-mcp</b><br/>current compatibility add-on until D19<br/>target: core/in-process SIFT tools")
      OpenCTI("<b>opencti-mcp</b> &rarr; <b>OpenCTI platform</b><br/>platform + worker + redis + rabbitmq + minio<br/>query-only; case_scoped = false")
      WinTriage("<b>windows-triage-mcp</b><br/>local baseline DBs<br/>query-only; case_scoped = false")
    end

    %% Note: OpenSearch and RAG are TARGET CORE, not long-term add-ons (D19/D23).
    %% OpenSearch may still appear through gateway.yaml/proxy compatibility until
    %% the later OpenSearch-core phase retires its add-on registration.
    %% RAG retrieval is a core control-plane tool over Supabase pgvector.

    %% -------------------------
    %% Flows
    %% -------------------------
    Portal -. "Operator actions / REST API<br/>(target: set ACTIVE CASE;<br/>authority pending ID-4/ID-5)" .-> Gateway
    Agents -. "MCP tool calls<br/>(ingest / search / query via Gateway only)" .-> Gateway

    Gateway -. "AuthZ, audit,<br/>case + workflow state,<br/><b>ENQUEUE jobs / pipelines</b><br/><i>active-case authority pending</i>" .-> Supabase
    Gateway -. "Mediated case-scoped<br/>search & retrieval<br/><i>target core OpenSearch tools</i>" .-> OpenSearch
    Gateway -. "OpenSearch compatibility add-on<br/><i>until D19 core move</i>" .-> OpenSearchCompat
    Gateway -. "Registered add-on tool calls<br/>query-only, audited under active case<br/><i>current config source: gateway.yaml</i>" .-> OpenCTI
    Gateway -. "Registered add-on tool calls<br/>query-only, audited under active case<br/><i>current config source: gateway.yaml</i>" .-> WinTriage
    OpenCTI -. "opencti_* indices<br/>(scoped role)" .-> OpenSearch

    Supabase == "Workers CLAIM durable jobs<br/>(poll + lease)" ==> EXECUTION
    EXECUTION -. "Status, steps, logs, parser runs,<br/>proposed findings, audit updates" .-> Supabase

    EXECUTION -. "Parsed artifacts / timeline /<br/>IOC indexing (+ provenance IDs)" .-> OpenSearch
    EXECUTION -. "Read immutable evidence /<br/>verify & register metadata" .-> Evidence
    EXECUTION -. "Generate reports" .-> Reports

    Reports -. "Review / download<br/>(via Gateway)" .-> Portal
  end

