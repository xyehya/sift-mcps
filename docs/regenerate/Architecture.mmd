flowchart TB

  %% =========================================================
  %% SIFT VM Autonomous DFIR Agent - target architecture.
  %%
  %% Canonical decisions reflected in this diagram (see
  %% 00_migration_charter.md "Confirmed Decisions (Locked)"):
  %%  - The Gateway is the SINGLE policy boundary. ALL REST APIs,
  %%    ALL MCP tool calls, and ALL privileged actions go through it.
  %%    Per-backend direct MCP routes (/mcp/{name}) are DISABLED.
  %%  - Supabase/Postgres is the authoritative control plane.
  %%  - Final auth target (D30): Supabase-issued JWTs for humans,
  %%    agents, MCP clients, workers, and services. PR02 hash-token
  %%    registry is a compatibility bridge until sunset.
  %%  - There is NEVER a direct job/invoke to the Evidence Vault.
  %%    Tool calls (ingest/search/etc.) enter the Gateway, which
  %%    enqueues durable jobs/pipelines in the control plane; workers
  %%    CLAIM (poll + SKIP LOCKED) those jobs and run the pipelines.
  %%  - TARGET: ACTIVE CASE is selected by the operator in the portal only,
  %%    is authoritative in the control plane, and the Gateway propagates it
  %%    to every backend/API/tool call. D32/PR03B drops env/config/pointer
  %%    active-case authority and does not generate active-case exports.
  %%  - OpenSearch 3.5.0 with security ENABLED is the derived
  %%    search/data plane. It is never authoritative.
  %%  - AI agents reach tools ONLY through Gateway MCP tools and run
  %%    deeper analysis in a sandboxed, allowlisted execution plane.
  %% Note: Mermaid auto-layout is not pixel-perfect.
  %% =========================================================

  subgraph SYSTEM["SIFT VM Autonomous DFIR Agent - Target Architecture"]
    direction TB

    %% -------------------------
    %% Clients
    %% -------------------------
    subgraph CLIENTS[" "]
      direction LR

      Portal("<b>Presentation Layer</b><br/>React + Vite Operator Portal<br/><br/>Case lifecycle, <b>ACTIVE CASE selection</b>,<br/>findings + approvals, timeline, TODOs, IOCs,<br/>evidence integrity, principal/JWT management,<br/>reports, AI-agent activity review")

      Agents("<b>AI Agent Clients</b><br/>Codex / Claude / Local MCP Clients<br/><br/>Supabase JWT target (D30)<br/>Gateway-mediated MCP tools only<br/>case-data tools are case-scoped;<br/>global add-ons are tool-scoped + audited<br/>(no direct backend, no direct OpenSearch)")
    end

    %% -------------------------
    %% Gateway - single policy boundary
    %% -------------------------
    Gateway("<b>Gateway / Broker Layer - SINGLE POLICY BOUNDARY</b><br/>FastAPI + FastMCP 3.0<br/>(one ASGI app: REST + aggregate mcp.http_app at /mcp)<br/><br/>ALL REST APIs + ALL MCP tool calls + ALL privileged actions<br/>Supabase JWT verification, AuthZ, case scope,<br/>tool scope, evidence gate, audit + policy enforcement,<br/>OpenSearch query mediation<br/><i>policy is SIFT-owned middleware/service logic</i><br/><i>per-backend direct MCP routes removed</i><br/><i>DB active-case authority per D32</i>")

    %% -------------------------
    %% Control plane (authoritative)
    %% -------------------------
    subgraph CONTROL["Case Control Plane - AUTHORITATIVE"]
      direction TB

      Supabase[("<b>Supabase Local / Postgres</b><br/>Auth + RLS + Storage<br/><i>Source of truth</i>")]

      subgraph CP_BOXES[" "]
        direction TB
        B1["<b>Identity + Auth + Case Membership</b><br/><i>Supabase JWT target per D30</i>"]
        B2["<b>Compatibility Token Registry</b> (hash-only)<br/><i>runtime dual-validation done PR02;<br/>bridge until D30/ID-6 sunset</i>"]
        B3["<b>Active Case State</b> (portal-set)<br/><i>DB authority; no env/pointer exports per D32</i>"]
        B4["<b>Cases / Findings / Approvals / TODOs / IOCs / Timeline refs</b>"]
        B5["<b>Evidence Metadata + Integrity + Anchoring state</b>"]
        B6["<b>Durable Jobs / Steps / Logs / Pipeline State</b>"]
        B7["<b>Audit Events</b>"]
        B8["<b>Reports + Report Artifacts</b>"]
        B9["<b>RAG Collections + Agent Skills (skills.md)</b>"]
      end

      Supabase --- B1
      Supabase --- B2
      Supabase --- B3
      Supabase --- B4
      Supabase --- B5
      Supabase --- B6
      Supabase --- B7
      Supabase --- B8
      Supabase --- B9
    end

    %% -------------------------
    %% Data plane + Evidence vault
    %% -------------------------
    OpenSearch[("<b>OpenSearch 3.5.0 (Security ON)</b><br/><b>Target core</b> derived search / data plane<br/><b>case-*</b> SIFT indices + <b>opencti_*</b> OpenCTI indices<br/>per-consumer scoped roles - agent has no cluster creds<br/>artifacts, timeline, IOCs, full-text + vector<br/><i>final core move pending OpenSearch phase</i>")]

    Evidence[("<b>Evidence Vault</b><br/>Immutable raw evidence files + hashes<br/>manifest + ledger proof artifacts")]

    %% -------------------------
    %% Execution plane
    %% -------------------------
    subgraph EXECUTION["Execution Plane - SIFT VM Workers"]
      direction TB

      Worker("<b>SIFT VM Worker Runtime</b><br/>Claim durable jobs from Postgres (poll + SKIP LOCKED)<br/>Ingestion pipelines, parsers, normalization,<br/>evidence operations, report generation")

      Sandbox["<b>Sandboxed Agent Tool Execution</b><br/>run_command / deeper extraction<br/>shell-free, allowlisted, case-jailed"]

      Worker --- Sandbox
    end

    Reports[("<b>Reports / Exports</b><br/>HTML / PDF / JSON bundles")]

    %% -------------------------
    %% Add-on MCP backends (target: registered in control-plane mcp_backends;
    %% current: read from gateway.yaml until D22/F-11 lands; reached ONLY
    %% through the Gateway aggregate policy path)
    %% -------------------------
    %% RG1 (2026-06-13): Diagram is archival/pre-migration state. Current state:
    %% - opensearch-mcp is a registered core add-on (seeded by install.sh).
    %% - forensic-rag-mcp is a registered core add-on (seeded by install.sh); tools are kb_*.
    %% - windows-triage-mcp REMOVED from repo; future external add-on candidate only.
    %% - opencti-mcp is an EXTERNAL add-on (never seeded by install.sh).
    %% - gateway.yaml static tokens are legacy fallback; mcp_backends (Postgres) is current.
    subgraph ADDONS["Add-on MCP Backends - registered in app.mcp_backends (RG1: updated)"]
      direction LR
      OpenSearchCompat("<b>opensearch-mcp</b><br/>core add-on seeded by install.sh<br/>namespace: opensearch")
      OpenCTI("<b>opencti-mcp</b> &rarr; <b>OpenCTI platform</b><br/>EXTERNAL add-on — not in core install path<br/>query-only; setup via scripts/setup-addon.sh")
      ForensicRAG("<b>forensic-rag-mcp</b><br/>core add-on seeded by install.sh<br/>namespace: kb — tools: kb_search_knowledge, kb_list_knowledge_sources, kb_get_knowledge_stats")
    end

    %% RG1: OpenSearch and forensic-rag-mcp are core add-ons registered in app.mcp_backends.
    %% RAG retrieval goes through the kb_* tools in forensic-rag-mcp (not a gateway-local shim).

    %% -------------------------
    %% Flows
    %% -------------------------
    Portal -. "Operator actions / REST API<br/>(set DB ACTIVE CASE per D32)" .-> Gateway
    Agents -. "Supabase JWT + MCP tool calls<br/>(ingest / search / query via Gateway only)" .-> Gateway

    Gateway -. "AuthZ, audit,<br/>case + workflow state,<br/><b>ENQUEUE jobs / pipelines</b><br/><i>DB active-case authority per D32</i>" .-> Supabase
    Gateway -. "Mediated case-scoped<br/>search & retrieval<br/><i>target core OpenSearch tools</i>" .-> OpenSearch
    Gateway -. "Core add-on tool calls (opensearch_*)<br/>seeded by install.sh" .-> OpenSearchCompat
    Gateway -. "External add-on tool calls (cti_*)<br/>query-only; registered separately" .-> OpenCTI
    Gateway -. "Core add-on tool calls (kb_*)<br/>seeded by install.sh" .-> ForensicRAG
    OpenCTI -. "opencti_* indices<br/>(scoped role)" .-> OpenSearch

    Supabase == "Workers CLAIM durable jobs<br/>(poll + lease)" ==> EXECUTION
    EXECUTION -. "Status, steps, logs, parser runs,<br/>proposed findings, audit updates" .-> Supabase

    EXECUTION -. "Parsed artifacts / timeline /<br/>IOC indexing (+ provenance IDs)" .-> OpenSearch
    EXECUTION -. "Read immutable evidence /<br/>verify & register metadata" .-> Evidence
    EXECUTION -. "Generate reports" .-> Reports

    Reports -. "Review / download<br/>(via Gateway)" .-> Portal
  end

