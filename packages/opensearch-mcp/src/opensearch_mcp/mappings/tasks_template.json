{
  "index_patterns": [
    "case-*-tasks-*"
  ],
  "template": {
    "settings": {
      "index.number_of_replicas": 0
    },
    "mappings": {
      "properties": {
        "@timestamp": {
          "type": "date"
        },
        "task.name": {
          "type": "keyword"
        },
        "task.author": {
          "type": "keyword"
        },
        "task.command": {
          "type": "keyword"
        },
        "task.arguments": {
          "type": "text"
        },
        "task.trigger_types": {
          "type": "keyword"
        },
        "task.user_id": {
          "type": "keyword"
        },
        "task.run_level": {
          "type": "keyword"
        },
        "task.enabled": {
          "type": "boolean"
        },
        "task.is_system": {
          "type": "boolean"
        },
        "task.description": {
          "type": "text"
        },
        "task.xml": {
          "type": "text"
        },
        "host.name": {
          "type": "keyword"
        },
        "host.id": {
          "type": "keyword"
        },
        "vhir.source_file": {
          "type": "keyword"
        },
        "vhir.ingest_audit_id": {
          "type": "keyword"
        },
        "vhir.parse_method": {
          "type": "keyword"
        },
        "pipeline_version": {
          "type": "keyword"
        },
        "triage.verdict": {
          "type": "keyword"
        },
        "triage.reason": {
          "type": "keyword"
        },
        "triage.lolbin": {
          "type": "boolean"
        },
        "triage.checked": {
          "type": "boolean"
        },
        "triage.expected_paths": {
          "type": "keyword"
        },
        "triage.confidence": {
          "type": "keyword"
        },
        "threat_intel.verdict": {
          "type": "keyword"
        },
        "threat_intel.confidence": {
          "type": "integer"
        },
        "threat_intel.labels": {
          "type": "keyword"
        },
        "threat_intel.source": {
          "type": "keyword"
        },
        "threat_intel.ioc_type": {
          "type": "keyword"
        },
        "threat_intel.ioc_value": {
          "type": "keyword"
        },
        "threat_intel.enriched_at": {
          "type": "date"
        },
        "threat_intel.checked": {
          "type": "boolean"
        }
      }
    }
  },
  "priority": 25
}
