{
  "index_patterns": [
    "case-*-vol-*"
  ],
  "template": {
    "settings": {
      "index.mapping.total_fields.limit": 500,
      "index.number_of_replicas": 0
    },
    "mappings": {
      "properties": {
        "@timestamp": {
          "type": "date",
          "ignore_malformed": true
        },
        "PID": {
          "type": "long",
          "ignore_malformed": true
        },
        "PPID": {
          "type": "long",
          "ignore_malformed": true
        },
        "Threads": {
          "type": "integer"
        },
        "Handles": {
          "type": "integer"
        },
        "SessionId": {
          "type": "integer"
        },
        "CreateTime": {
          "type": "date",
          "ignore_malformed": true
        },
        "ExitTime": {
          "type": "date",
          "ignore_malformed": true
        },
        "Created": {
          "type": "date",
          "ignore_malformed": true
        },
        "LoadTime": {
          "type": "date",
          "ignore_malformed": true
        },
        "LastModified": {
          "type": "date",
          "ignore_malformed": true
        },
        "LastWriteTime": {
          "type": "date",
          "ignore_malformed": true
        },
        "Last Write Time": {
          "type": "date",
          "ignore_malformed": true
        },
        "LocalPort": {
          "type": "integer"
        },
        "ForeignPort": {
          "type": "integer"
        },
        "host.name": {
          "type": "keyword"
        },
        "host.id": {
          "type": "keyword"
        },
        "vhir.source_file": {
          "type": "keyword"
        },
        "vhir.ingest_audit_id": {
          "type": "keyword"
        },
        "vhir.parse_method": {
          "type": "keyword"
        },
        "pipeline_version": {
          "type": "keyword"
        },
        "triage.verdict": {
          "type": "keyword"
        },
        "triage.reason": {
          "type": "keyword"
        },
        "triage.lolbin": {
          "type": "boolean"
        },
        "triage.checked": {
          "type": "boolean"
        },
        "triage.expected_paths": {
          "type": "keyword"
        },
        "triage.confidence": {
          "type": "keyword"
        },
        "threat_intel.verdict": {
          "type": "keyword"
        },
        "threat_intel.confidence": {
          "type": "integer"
        },
        "threat_intel.labels": {
          "type": "keyword"
        },
        "threat_intel.source": {
          "type": "keyword"
        },
        "threat_intel.ioc_type": {
          "type": "keyword"
        },
        "threat_intel.ioc_value": {
          "type": "keyword"
        },
        "threat_intel.enriched_at": {
          "type": "date"
        },
        "threat_intel.checked": {
          "type": "boolean"
        }
      }
    }
  },
  "priority": 15
}
