        "source.geo.country_name": {"type": "keyword"},
        "source.geo.city_name": {"type": "keyword"},
        "source.geo.region_name": {"type": "keyword"},
        "source.geo.continent_name": {"type": "keyword"},
        "source.geo.location": {"type": "geo_point"}
      }
    }
  },
  "priority": 23
}
