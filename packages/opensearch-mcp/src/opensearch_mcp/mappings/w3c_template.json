        "s-ip": {"type": "ip", "ignore_malformed": true},
        "src-ip": {"type": "ip", "ignore_malformed": true},
        "dst-ip": {"type": "ip", "ignore_malformed": true},
        "source.ip": {"type": "ip", "ignore_malformed": true},
        "destination.ip": {"type": "ip", "ignore_malformed": true},
        "s-port": {"type": "integer"},
        "dst-port": {"type": "integer"},
        "src-port": {"type": "integer"},
        "sc-status": {"type": "integer"},
        "sc-substatus": {"type": "integer"},
        "time-taken": {"type": "integer"},
        "size": {"type": "integer"},
        "host.name": {"type": "keyword"},
        "host.id": {"type": "keyword"},
        "sift.source_file": {"type": "keyword"},
        "sift.ingest_audit_id": {"type": "keyword"},
