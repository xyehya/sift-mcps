                },
                "index": {
                  "description": "Case index name.",
                  "title": "Index",
                  "type": "string"
                },
                "size": {
                  "description": "Human store size, e.g. '1.2gb'.",
                  "title": "Size",
                  "type": "string"
                },
                "status": {
                  "description": "Index status reported by cat indices.",
                  "title": "Status",
                  "type": "string"
                }
