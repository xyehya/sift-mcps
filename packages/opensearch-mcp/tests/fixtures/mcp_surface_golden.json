            "title": "Indices",
            "type": "array"
          },
          "total_indices": {
            "description": "Number of case-* indices returned.",
            "title": "Total Indices",
            "type": "integer"
          }
        },
        "required": [
          "cluster_status",
          "indices",
          "total_indices"
        ],
        "title": "StatusOut",
        "type": "object"
      },
      "title": "Cluster & Index Status"
