      },
      "name": "opensearch_status",
      "output_schema": {
        "properties": {
          "cluster_status": {
            "description": "Cluster health status; single-node yellow may be annotated normal.",
            "title": "Cluster Status",
            "type": "string"
          },
          "indices": {
            "description": "All case-* indices, sorted by name.",
