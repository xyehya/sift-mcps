{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SiftBackendManifest",
  "type": "object",
  "properties": {
    "spec_version": {
      "type": "string",
      "pattern": "^1\\.[0-9]+$"
    },
    "name": { "type": "string" },
    "version": { "type": "string" },
    "tier": {
      "type": "string",
      "enum": ["addon"]
    },
    "transport": {
      "type": "string",
      "enum": ["stdio", "http"]
    },
    "namespace": { "type": "string" },
    "default_case_scoped": { "type": "boolean" },
    "data_plane": {
      "type": "object",
      "properties": {
        "dependencies": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "writes": { "type": "boolean" },
        "notes": { "type": "string" }
      },
      "additionalProperties": true
    },
    "instructions": { "type": "string" },
    "instructions_path": { "type": "string" },
    "capabilities": {
      "type": "object",
      "properties": {
        "provides": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["reference", "search", "ingest", "enrichment", "baseline", "threat-intel"]
          },
          "uniqueItems": true
        },
        "requires": {
          "type": "array",
          "items": { "type": "string" }
        },
        "enriches_responses": { "type": "boolean" }
      },
      "required": ["provides", "requires", "enriches_responses"],
      "additionalProperties": false
    },
    "tools": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "read_only": { "type": "boolean" },
          "readOnlyHint": { "type": "boolean" },
          "evidence_class": {
            "type": "string",
            "enum": ["read_only", "analysis", "mutating"]
          },
          "category": {
            "type": "string",
            "enum": [
              "evidence-survey",
              "ingest",
              "search-analysis",
              "enrichment",
              "baseline-check",
              "threat-intel",
              "admin"
            ]
          },
          "recommended_phase": {
            "type": "string",
            "enum": ["SURVEY", "INGEST", "ANALYZE", "CORRELATE", "FINDING"]
          },
          "health": { "type": "boolean" },
          "health_args": { "type": "object" },
          "case_scoped": { "type": "boolean" },
          "hidden_from_agent": { "type": "boolean" },
          "when_to_use": { "type": "string" },
          "avoid_when": { "type": "string" },
          "output_notes": { "type": "string" },
          "output_shape": { "type": "string" },
          "response_shaping": { "type": "string" },
          "defer_loading": { "type": "boolean" },
          "defer_loading_rationale": { "type": "string" },
          "usage_examples": {
            "description": "OSX2: advanced-tool-use realistic call examples (minimal/partial/full). Metadata only — does not change dispatch.",
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "description": { "type": "string" },
                "arguments": { "type": "object" }
              },
              "required": ["arguments"],
              "additionalProperties": false
            }
          },
          "required_scopes": {
            "type": "array",
            "items": { "type": "string" },
            "uniqueItems": true
          },
          "safe_case_argument_names": {
            "description": "OS2: argument names the Gateway may safely inject the DB active case_id into. An empty list means the tool is case-scoped but resolves the active case internally (no injection argument). Absent means unknown — the Gateway falls back to schema-property detection and denies fail-closed if nothing is found.",
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["case_id", "case_key"]
            },
            "uniqueItems": true
          },
          "scope_enforcement": {
            "description": "OS5: how required_scopes are enforced for a mutating tool (e.g. 'gateway_primary_env_fallback').",
            "type": "string"
          },
          "enrichment_policy": {
            "description": "OS5: declares enrichment as audited, scope-gated, pollable derived-state mutation (derived_state_only, audit_required, status_pollable, poll_via, poll_discriminator).",
            "type": "object"
          },
          "prohibited_operations": {
            "description": "OS5: operations a mutating/enrichment tool must never perform (e.g. approve_findings, alter_evidence, decide_reports).",
            "type": "array",
            "items": { "type": "string" },
            "uniqueItems": true
          },
          "secret_leak_guarantee": {
            "description": "OS5: statement that the tool's agent-facing response carries no credentials/DSNs/paths.",
            "type": "string"
          },
          "receipt_policy": {
            "description": "OS5: DB-active host-correction receipt contract (db_active_mode, receipt_fields, fail_closed, no_path_leak).",
            "type": "object"
          }
        },
        "required": [
          "name",
          "description",
          "read_only",
          "readOnlyHint",
          "evidence_class",
          "category",
          "recommended_phase"
        ],
        "additionalProperties": false
      }
    },
    "health": {
      "type": "string"
    },
    "authority_contract": {
      "type": "object",
      "description": "Declares the add-on as a non-authoritative, query-only reference/derived plane. Advisory metadata; the Gateway remains the enforcement boundary.",
      "properties": {
        "non_authoritative": { "type": "boolean" },
        "plane": { "type": "string" },
        "query_only": { "type": "boolean" },
        "authority_disclaimer": { "type": "string" },
        "prohibited_operations": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    }
  },
  "required": ["spec_version", "name", "version", "tier", "transport", "namespace", "capabilities", "tools", "health"],
  "additionalProperties": false
}
