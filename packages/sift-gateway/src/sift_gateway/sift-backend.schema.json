{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SiftBackendManifest",
  "type": "object",
  "properties": {
    "spec_version": {
      "type": "string",
      "pattern": "^1\\.[0-9]+$"
    },
    "name": { "type": "string" },
    "version": { "type": "string" },
    "tier": {
      "type": "string",
      "enum": ["addon"]
    },
    "transport": {
      "type": "string",
      "enum": ["stdio", "http"]
    },
    "namespace": { "type": "string" },
    "instructions": { "type": "string" },
    "instructions_path": { "type": "string" },
    "capabilities": {
      "type": "object",
      "properties": {
        "provides": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["reference", "search", "ingest", "enrichment", "baseline", "threat-intel"]
          },
          "uniqueItems": true
        },
        "requires": {
          "type": "array",
          "items": { "type": "string" }
        },
        "enriches_responses": { "type": "boolean" }
      },
      "required": ["provides", "requires", "enriches_responses"],
      "additionalProperties": false
    },
    "tools": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "read_only": { "type": "boolean" },
          "readOnlyHint": { "type": "boolean" },
          "evidence_class": {
            "type": "string",
            "enum": ["read_only", "analysis", "mutating"]
          },
          "category": {
            "type": "string",
            "enum": [
              "evidence-survey",
              "ingest",
              "search-analysis",
              "enrichment",
              "baseline-check",
              "threat-intel",
              "admin"
            ]
          },
          "recommended_phase": {
            "type": "string",
            "enum": ["SURVEY", "INGEST", "ANALYZE", "CORRELATE", "FINDING"]
          },
          "health": { "type": "boolean" },
          "health_args": { "type": "object" },
          "hidden_from_agent": { "type": "boolean" },
          "when_to_use": { "type": "string" },
          "avoid_when": { "type": "string" },
          "output_notes": { "type": "string" }
        },
        "required": [
          "name",
          "description",
          "read_only",
          "readOnlyHint",
          "evidence_class",
          "category",
          "recommended_phase"
        ],
        "additionalProperties": false
      }
    },
    "health": {
      "type": "string"
    }
  },
  "required": ["spec_version", "name", "version", "tier", "transport", "namespace", "capabilities", "tools", "health"],
  "additionalProperties": false
}
