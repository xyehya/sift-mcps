#!/usr/bin/env bash
# Root-owned privileged helper for sealed-evidence filesystem hardening
# (B-MVP-048).
#
# Why this exists
# ---------------
# When an operator seals evidence, the bytes must end up (a) owned by the
# gateway service user and (b) immutable (chattr +i / FS_IMMUTABLE_FL). The
# gateway/worker run as the NON-root service user and the unit deliberately does
# NOT carry CAP_CHOWN/CAP_FOWNER, so re-owning a root:root operator-copied file
# is not possible in-process. This narrow helper is reached through a
# command-specific sudoers drop-in (`sudo -n /usr/local/sbin/sift-seal-evidence
# --service-user <u> --path <abs>`), keeps ALL privileged work here, and does
# only two things to ONE server-revalidated path: chown -> service user, then
# set the immutable flag.
#
# Hostile-input discipline (the caller is trusted, the args are not)
# -----------------------------------------------------------------
#   * --case-dir must be an ABSOLUTE, resolvable directory; --path is then bound
#     STRICTLY under <case-dir>/evidence/ (anchored prefix, not a loose
#     "/evidence/" substring — that would let any path with an evidence/ segment
#     through; B-MVP-048 security review).
#   * --path must be an ABSOLUTE, fully-resolved path (realpath == argument),
#     must NOT be a symlink, MUST be a regular file, and MUST have link count 1
#     (a hardlink could alias a root-owned file outside evidence/).
#   * --service-user must be an existing local account.
# Any deviation aborts with a non-zero status BEFORE any privileged action.
set -euo pipefail

die() {
  printf 'sift-seal-evidence: %s\n' "$*" >&2
  exit 2
}

service_user=""
path=""
case_dir=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --service-user) service_user="${2:-}"; shift 2 ;;
    --path) path="${2:-}"; shift 2 ;;
    --case-dir) case_dir="${2:-}"; shift 2 ;;
    --) shift; break ;;
    *) die "unknown option: $1" ;;
  esac
done

[[ "${EUID}" -eq 0 ]] || die "must run as root"
[[ -n "${service_user}" ]] || die "missing --service-user"
[[ -n "${path}" ]] || die "missing --path"
[[ -n "${case_dir}" ]] || die "missing --case-dir"

# Service user must exist; refuse otherwise (no chown to an unknown uid).
id -u "${service_user}" >/dev/null 2>&1 || die "service user not found: ${service_user}"
[[ "${service_user}" =~ ^[a-z_][a-z0-9_-]*[$]?$ ]] || die "invalid service user name"

# Resolve the case dir to a canonical evidence root. --case-dir binds --path to a
# SPECIFIC case (the gateway passes the DB-authoritative case dir); without this
# the "/evidence/" check below would be an unanchored substring that a caller
# could satisfy with ANY path containing an evidence/ segment (B-MVP-048 review).
[[ "${case_dir}" = /* ]] || die "case-dir must be absolute"
case "${case_dir}" in
  *$'\n'*|*$'\t'*) die "case-dir contains control characters" ;;
esac
case_resolved="$(realpath -e -- "${case_dir}" 2>/dev/null)" || die "case-dir does not resolve: ${case_dir}"
[[ -d "${case_resolved}" ]] || die "case-dir is not a directory: ${case_resolved}"
evidence_root="${case_resolved%/}/evidence"
[[ -d "${evidence_root}" ]] || die "no evidence/ dir under case-dir: ${case_resolved}"

# Path must be absolute and already canonical (no symlinks / .. / relative bits).
[[ "${path}" = /* ]] || die "path must be absolute"
case "${path}" in
  *$'\n'*|*$'\t'*) die "path contains control characters" ;;
esac
resolved="$(realpath -e -- "${path}" 2>/dev/null)" || die "path does not resolve: ${path}"
[[ "${resolved}" == "${path}" ]] || die "path is not canonical (symlink/.. component): ${path}"

# Must live strictly UNDER this case's evidence/ root (anchored prefix, not a
# loose substring) and be a plain regular file.
[[ "${resolved}" == "${evidence_root}/"* ]] \
  || die "path is not inside this case's evidence/ root: ${resolved}"
[[ -L "${resolved}" ]] && die "refusing to operate on a symlink: ${resolved}"
[[ -f "${resolved}" ]] || die "not a regular file: ${resolved}"

# Reject hardlinked targets: a link count > 1 means the same inode is reachable
# from outside evidence/ (e.g. a hardlink to a root-owned system file), so chown
# /chattr +i would silently affect that other path too. Sealed evidence bytes are
# single-linked operator copies; nlink > 1 is itself suspicious. Fail closed.
nlink="$(stat -c '%h' -- "${resolved}" 2>/dev/null)" || die "cannot stat: ${resolved}"
[[ "${nlink}" == "1" ]] || die "refusing to harden a hardlinked file (nlink=${nlink}): ${resolved}"

# Privileged actions, in order: chown first (chattr +i would block chown), then
# set the immutable flag.
chown -- "${service_user}:${service_user}" "${resolved}" || die "chown failed: ${resolved}"
chattr +i -- "${resolved}" || die "chattr +i failed: ${resolved}"

exit 0
